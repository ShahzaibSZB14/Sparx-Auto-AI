{
    "manifest_version": 3,
    "name": "Sparx AI Tools",
    "version": "4.3.2026",
    "permissions": [
        "activeTab",
        "tabs",
        "scripting",
        "clipboardWrite",
        "storage",
        "notifications"
    ],
    "host_permissions": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://cdn.sparx-learning.com/*"
    ],
    "icons": {
        "128": "cdn/img/logo.png"
    },
    "background": {
        "service_worker": "api/sw.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://maths.sparx-learning.com/*"
            ],
            "js": [
                "maths/content.js"
            ]
        },
        {
            "matches": [
                "https://reader.sparx-learning.com/*"
            ],
            "js": [
                "reader/content.js"
            ]
        },
        {
            "matches": [
                "https://science.sparx-learning.com/*"
            ],
            "js": [
                "science/content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "cdn/img/*.svg",
                "cdn/img/*.png",
                "cdn/css/*.css"
            ],
            "matches": [
                "https://*.sparx-learning.com/*"
            ]
        }
    ]
}
